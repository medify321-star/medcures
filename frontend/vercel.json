{
  "buildCommand": "npm run build",
  "devCommand": "npm start",
  "installCommand": "npm install",
  "framework": "create-react-app",
  "public": false,
  "env": {
    "REACT_APP_BACKEND_URL": "@backend_url"
  },
  "envPrefix": "REACT_APP_",
  "regions": ["iad1"],
  "functions": {
    "frontend/src/**/*.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
