# Production Environment Template
# Copy this as ./backend/.env for production deployment
# FILL IN ALL VALUES BEFORE DEPLOYMENT

# ===== REQUIRED =====

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY="CHANGE_THIS_TO_A_STRONG_RANDOM_STRING_MINIMUM_32_CHARS"

# Administrator email for system alerts
FOUNDER_EMAIL="admin@yourdomain.com"

# ===== DATABASE (Choose One) =====

# Option 1: MongoDB Atlas
# MONGO_URL="mongodb+srv://username:password@cluster.mongodb.net/medcures?retryWrites=true"
# DB_NAME="medcures"

# Option 2: PostgreSQL (Recommended for Healthcare)
# DATABASE_URL="postgresql://username:password@host:5432/medcures"

# ===== AI/LLM (Optional but Recommended) =====

# Get from https://openrouter.ai
OPENROUTER_API_KEY="sk-or-v1-your-api-key-here"

# ===== SECURITY =====

# Production domains only - NO WILDCARDS
# Format: "https://domain1.com,https://domain2.com"
CORS_ORIGINS="https://yourdomain.com,https://app.yourdomain.com"

# ===== DEPLOYMENT =====

# Must be "production"
ENVIRONMENT="production"

# Server configuration
BACKEND_HOST="0.0.0.0"
BACKEND_PORT="8000"
BACKEND_RELOAD="false"

# ===== OPTIONAL: MONITORING & SECURITY =====

# Sentry error tracking: https://sentry.io
# SENTRY_DSN="https://your-sentry-dsn@sentry.io/projectid"

# Google Cloud Logging (auto-enabled on Cloud Run)
# GCP_PROJECT_ID="your-gcp-project-id"

# Rate limiting
MAX_REQUESTS_PER_MINUTE="60"

# Session timeout (minutes)
SESSION_TIMEOUT="1440"

# ===== SECURITY CHECKLIST =====
# Before deploying:
# ✓ Change JWT_SECRET_KEY (minimum 32 random characters)
# ✓ Set FOUNDER_EMAIL to your email
# ✓ Configure database connection
# ✓ Set CORS_ORIGINS to your production domain(s)
# ✓ Set ENVIRONMENT="production"
# ✓ Never commit this file with real values
# ✓ Use Cloud Secret Manager in GCP to store these values
# ✓ Never share this file with anyone
# ✓ Rotate API keys every 90 days
